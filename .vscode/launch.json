{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Edge Mining Debugger: Standard Mode",
            "type": "debugpy",
            "request": "launch",
            "console": "integratedTerminal",
            "module": "edge_mining",
            "args": ["standard"],
            "python": "${command:python.interpreterPath}",
            "cwd": "${workspaceFolder}/core"
        },
        {
            "name": "Edge Mining Debugger: CLI Mode",
            "type": "debugpy",
            "request": "launch",
            "console": "integratedTerminal",
            "module": "edge_mining",
            "args": ["cli", "interactive"],
            "python": "${command:python.interpreterPath}",
            "cwd": "${workspaceFolder}/core"
        }
    ]
}
